{
  "name": "gemini-asset-processor/craft-gems",
  "description": "Process Craft CMS assets using Gemini Gems",
  "type": "craft-plugin",
  "license": "MIT",
  "require": {
    "craftcms/cms": "^4.0.0|^5.0.0"
  },
  "autoload": {
    "psr-4": {
      "gemini\\craftgems\\": "src/"
    }
  },
  "extra": {
    "name": "Craft Gems",
    "handle": "craft-gems",
    "class": "gemini\\craftgems\\CraftGems",
    "hasCpSettings": true,
    "hasCpSection": false
  }
}